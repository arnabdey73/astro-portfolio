---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getPageBySlug } from '../utils/createPages.js';

// Sample projects data (will be replaced by real data from GitHub)
const projects = [
  {
    title: 'Cloud Infrastructure Automation',
    description: 'An extensive Terraform module collection for automating AWS and Azure infrastructure provisioning with best practices for security and scalability.',
    technologies: ['Terraform', 'AWS', 'Azure', 'GitHub Actions', 'Python'],
    image: '/blog-placeholder-1.jpg',
    link: '#'
  },
  {
    title: 'Kubernetes Monitoring Suite',
    description: 'A comprehensive monitoring solution for Kubernetes clusters using Prometheus, Grafana, and custom exporters to provide detailed insights into cluster health and performance.',
    technologies: ['Kubernetes', 'Prometheus', 'Grafana', 'Go', 'Helm'],
    image: '/blog-placeholder-2.jpg',
    link: '#'
  },
  {
    title: 'CI/CD Pipeline Framework',
    description: 'A modular CI/CD framework built on Jenkins that enables teams to rapidly set up standardized deployment pipelines with security scanning, testing, and deployment strategies.',
    technologies: ['Jenkins', 'Docker', 'Groovy', 'SonarQube', 'Bash'],
    image: '/blog-placeholder-3.jpg',
    link: '#'
  },
  {
    title: 'Microservices Application Platform',
    description: 'A cloud-native application platform built on Kubernetes that provides standardized tooling, deployment patterns, and observability for microservices architecture.',
    technologies: ['Kubernetes', 'Istio', 'React', 'Node.js', 'MongoDB'],
    image: '/blog-placeholder-4.jpg',
    link: '#'
  }
];

// Fetch the projects page content
const projectsPage = await getPageBySlug('/projects') || {
  title: 'Projects',
  content: '<h1>My Projects</h1><p>Here are some of the projects I\'ve worked on throughout my career. These projects showcase my expertise in cloud infrastructure, DevOps practices, and web development.</p>'
};
---

<BaseLayout 
  title={`${projectsPage.title} | Arnab Dey`}
  description="Explore projects by Arnab Dey showcasing cloud infrastructure, DevOps automation, and web development expertise."
  layout="standard"
>
  <Header slot="header" />
  
  <main class="projects-page">
    <div class="container">
      <div class="intro" set:html={projectsPage.content}></div>
      
      <div class="projects-grid">
        {projects.map(project => (
          <div class="project-card">
            <div class="project-image">
              <img src={project.image} alt={project.title} loading="lazy" />
            </div>
            <div class="project-content">
              <h2>{project.title}</h2>
              <p>{project.description}</p>
              <div class="project-technologies">
                {project.technologies.map(tech => (
                  <span class="tech-tag">{tech}</span>
                ))}
              </div>
              <a href={project.link} class="project-link">View Project →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
  
  <Footer slot="footer" />
</BaseLayout>

<style>
  .projects-page {
    padding: 4rem 0;
    min-height: 70vh;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  
  .intro {
    margin-bottom: 3rem;
    max-width: 800px;
  }
  
  .intro h1 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    color: var(--primary-color);
  }
  
  .intro p {
    font-size: 1.1rem;
    line-height: 1.7;
  }
  
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(500px, 1fr));
    gap: 2.5rem;
  }
  
  .project-card {
    border-radius: 8px;
    overflow: hidden;
    background-color: var(--card-background);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
  }
  
  .project-image {
    height: 250px;
    overflow: hidden;
  }
  
  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .project-card:hover .project-image img {
    transform: scale(1.05);
  }
  
  .project-content {
    padding: 1.5rem;
  }
  
  .project-content h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--heading-color);
  }
  
  .project-content p {
    margin-bottom: 1.5rem;
    color: var(--text-color);
    line-height: 1.6;
  }
  
  .project-technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  
  .tech-tag {
    background-color: var(--hover-background);
    color: var(--primary-color);
    padding: 0.3rem 0.8rem;
    border-radius: 30px;
    font-size: 0.85rem;
    font-weight: 500;
  }
  
  .project-link {
    display: inline-block;
    color: var(--primary-color);
    font-weight: 600;
    transition: color 0.2s ease;
  }
  
  .project-link:hover {
    color: var(--primary-dark);
  }
  
  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    
    .project-image {
      height: 200px;
    }
  }
</style>
