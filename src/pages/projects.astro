---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MarkdownContent from '../components/MarkdownContent.astro';
import { loadMarkdownContent } from '../utils/fetchContent.js';

// Fetch the projects page content
const { content: projectsContent, metadata: projectsMetadata } = await loadMarkdownContent('/projects');

// Sample projects data
const projects = [
  {
    title: 'Azure Core Governance Infrastructure as Code',
    description: 'This project implements Azure governance patterns at enterprise scale, providing a foundation for Azure landing zones with comprehensive governance controls.',
    technologies: ['Terraform', 'Azure', 'Security', 'Governance'],
    image: '/blog-placeholder-1.jpg',
    link: 'https://github.com/arnabdey73/iac-azure-core-governance'
  },
  {
    title: 'Azure Cost Optimizer',
    description: 'A comprehensive solution to help optimize Azure costs by leveraging Azure SDKs and tools for cost analysis and resource management.',
    technologies: ['Python', 'Azure', 'Cost Management', 'Terraform'],
    image: '/blog-placeholder-2.jpg',
    link: 'https://github.com/arnabdey73/azure-cost-optimizer'
  },
  {
    title: 'Portfolio Website',
    description: 'Personal portfolio website built with Astro, featuring dark mode toggle, external blog integration, and responsive design.',
    technologies: ['Astro', 'JavaScript', 'HTML5', 'CSS3'],
    image: '/blog-placeholder-3.jpg',
    link: 'https://github.com/arnabdey73/astro-portfolio'
  }
];
---

<BaseLayout 
  title={`${projectsMetadata.title} | Arnab Dey`}
  description="Explore projects by Arnab Dey showcasing cloud infrastructure, DevOps automation, and web development expertise."
  layout="standard"
>
  <Header slot="header" />
  
  <main class="projects-page">
    <div class="container">      <div class="intro">
        <h1>My Projects</h1>
        <p>Here are some of the projects I've worked on throughout my career. These projects showcase my expertise in cloud infrastructure, DevOps practices, and web development.</p>
        <MarkdownContent content={projectsContent} className="project-content-md" />
      </div>
      
      <div class="projects-grid">
        {projects.map(project => (
          <div class="project-card">
            <div class="project-image">
              <img src={project.image} alt={project.title} loading="lazy" />
            </div>
            <div class="project-content">
              <h2>{project.title}</h2>
              <p>{project.description}</p>
              <div class="project-technologies">
                {project.technologies.map(tech => (
                  <span class="tech-tag">{tech}</span>
                ))}
              </div>
              <a href={project.link} class="project-link" target="_blank" rel="noopener noreferrer">View Project →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
  
  <Footer slot="footer" />
</BaseLayout>

<style>
  .projects-page {
    padding: 4rem 0;
    min-height: 70vh;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  
  .intro {
    margin-bottom: 3rem;
    max-width: 800px;
  }
  
  .intro h1 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    color: var(--primary-color);
  }
  
  .intro p {
    font-size: 1.1rem;
    line-height: 1.7;
  }
  
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(500px, 1fr));
    gap: 2.5rem;
  }
  
  .project-card {
    border-radius: 8px;
    overflow: hidden;
    background-color: var(--card-background);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
  }
  
  .project-image {
    height: 250px;
    overflow: hidden;
  }
  
  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .project-card:hover .project-image img {
    transform: scale(1.05);
  }
  
  .project-content {
    padding: 1.5rem;
  }
  
  .project-content h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--heading-color);
  }
  
  .project-content p {
    margin-bottom: 1.5rem;
    color: var(--text-color);
    line-height: 1.6;
  }
  
  .project-technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  
  .tech-tag {
    background-color: var(--hover-background);
    color: var(--primary-color);
    padding: 0.3rem 0.8rem;
    border-radius: 30px;
    font-size: 0.85rem;
    font-weight: 500;
  }
  
  .project-link {
    display: inline-block;
    color: var(--primary-color);
    font-weight: 600;
    transition: color 0.2s ease;
  }
  
  .project-link:hover {
    color: var(--primary-dark);
  }
  
  /* Project markdown specific styles */
  .project-content-md {
    margin-top: 2rem;
  }
  
  .project-content-md .project-card {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
  }
  
  .project-content-md .project-card:last-child {
    border-bottom: none;
  }
  
  .project-content-md .tech-icons-mini {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 1rem 0;
  }
  
  .project-content-md .tech-item-mini {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.8rem;
    background-color: var(--hover-background);
    border-radius: 20px;
    font-size: 0.85rem;
  }
  
  .project-content-md .github-link {
    margin-top: 1rem;
  }
  
  .project-content-md .github-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background-color: var(--card-background);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    transition: all 0.2s ease;
  }
  
  .project-content-md .github-button:hover {
    background-color: var(--primary-color);
    color: white;
    border-color: var(--primary-color);
  }
  
  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    
    .project-image {
      height: 200px;
    }
  }
</style>
