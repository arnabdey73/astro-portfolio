---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MarkdownContent from '../components/MarkdownContent.astro';
import { loadMarkdownContent } from '../utils/fetchContent.js';

// Fetch the about page content
const { content: aboutContent, metadata: aboutMetadata } = await loadMarkdownContent('/about');
---

<BaseLayout 
  title={`${aboutMetadata.title} | Arnab Dey`}
  description="Learn more about Arnab Dey, a Cloud & DevOps Engineer specializing in modern infrastructure and automation."
  layout="standard"
>
  <Header slot="header" />
    <main class="about-page">
    <div class="container">
      <MarkdownContent content={aboutContent} />
    </div>
  </main>
  
  <Footer slot="footer" />
</BaseLayout>

<style>
  .about-page {
    padding: 4rem 0;
    min-height: 70vh;
  }
  
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  
  article {
    line-height: 1.7;
  }
  
  article h1 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: var(--primary-color);
  }
  
  article h2 {
    font-size: 1.8rem;
    margin: 2.5rem 0 1rem;
    color: var(--heading-color);
  }
  
  article p {
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
  }
  
  article ul {
    margin: 1.5rem 0;
    padding-left: 2rem;
  }
  
  article li {
    margin-bottom: 0.75rem;
  }
  
  /* Timeline specific styles for about page */
  .timeline {
    position: relative;
    padding: 2rem 0 0;
  }
  
  .timeline::before {
    content: '';
    position: absolute;
    top: 0;
    left: 1rem;
    height: 100%;
    width: 2px;
    background-color: var(--primary-color);
    opacity: 0.3;
  }
  
  .timeline-entry {
    position: relative;
    margin-bottom: 3rem;
    padding-left: 3rem;
  }
  
  .timeline-entry::before {
    content: '';
    position: absolute;
    top: 0.5rem;
    left: 0;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background-color: var(--primary-color);
  }
  
  .timeline-entry h3 {
    margin-bottom: 1rem;
    color: var(--primary-color);
  }
  
  .content-page ul {
    list-style-type: disc;
    padding-left: 2rem;
    margin: 1rem 0;
  }
  
  .content-page ul li {
    margin-bottom: 0.5rem;
  }
  
  @media (max-width: 768px) {
    .timeline::before {
      left: 0.75rem;
    }
    
    .timeline-entry {
      padding-left: 2rem;
    }
    
    .timeline-entry::before {
      width: 0.75rem;
      height: 0.75rem;
    }
  }
</style>
