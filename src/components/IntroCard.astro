---
// IntroCard component - Hero section for the portfolio homepage
---

<section class="intro-card">
  <div class="container">
    <div class="intro-content">
      <div class="intro-text">
        <h1>Hi, I'm <span class="highlight">Arnab Dey</span></h1>
        <h2>Cloud & DevOps Engineer</h2>
        <p>
          I build scalable cloud infrastructure and develop efficient DevOps pipelines.
          Passionate about automation, containerization, and modern development practices.
        </p>
        <div class="cta-buttons">
          <a href="/projects" class="button primary">View My Projects</a>
          <a href="/contact" class="button secondary">Get In Touch</a>
        </div>
      </div>      <div class="intro-image">
        <div class="profile-flip-container">
          <div class="profile-flipper">          <div class="profile-front">
            <img 
              src="/images/avatar.jpg" 
              alt="Arnab Dey" 
              width="400" 
              height="400"
              loading="eager"
              onerror="this.src='/profile-placeholder.png'; this.onerror=null;"
            />
          </div>
          <div class="profile-back">
            <img 
              src="/images/avatar2.jpg" 
              alt="Arnab Dey - Alternative" 
              width="400" 
              height="400"
              loading="eager"
              onerror="this.src='/images/banner.jpeg'; this.onerror=null;"
            />
          </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .intro-card {
    padding: 5rem 0;
    min-height: 85vh;
    display: flex;
    align-items: center;
  }
  
  .intro-content {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  
  .intro-text {
    flex: 1;
  }
  
  .intro-text h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    line-height: 1.1;
  }
  
  .intro-text h2 {
    font-size: 2rem;
    color: var(--primary-color);
    margin-bottom: 1.5rem;
  }
  
  .intro-text p {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    max-width: 600px;
  }
  
  .highlight {
    color: var(--primary-color);
    position: relative;
  }
  
  .cta-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }
  
  .button {
    display: inline-block;
    padding: 0.8rem 1.8rem;
    border-radius: 4px;
    font-weight: 600;
    transition: all 0.3s ease;
  }
  
  .button.primary {
    background-color: var(--primary-color);
    color: white;
  }
  
  .button.primary:hover {
    background-color: var(--primary-dark);
    transform: translateY(-2px);
  }
  
  .button.secondary {
    border: 2px solid var(--primary-color);
    color: var(--primary-color);
    background: transparent;
  }
  
  .button.secondary:hover {
    background-color: var(--primary-color);
    color: white;
    transform: translateY(-2px);
  }
    .intro-image {
    flex: 1;
    display: flex;
    justify-content: center;
    perspective: 1000px; /* 3D effect */
  }
    /* Flip container */
  .profile-flip-container {
    width: 400px;
    height: 400px;
    position: relative;
    cursor: pointer;
    animation: float 6s ease-in-out infinite;
  }
  
  /* Floating animation */
  @keyframes float {
    0% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-15px);
    }
    100% {
      transform: translateY(0px);
    }
  }
  
  /* Flipper - contains front and back */
  .profile-flipper {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.8s cubic-bezier(0.455, 0.03, 0.515, 0.955);
    transform-style: preserve-3d;
  }
  
  /* Flip animation on hover */
  .profile-flip-container:hover .profile-flipper {
    transform: rotateY(180deg);
  }
  
  /* Add a glow effect on hover */
  .profile-flip-container:hover {
    animation: float 6s ease-in-out infinite, glow 1.5s ease-in-out infinite alternate;
  }
    @keyframes glow {
    from {
      box-shadow: 0 0 10px rgba(var(--primary-color-rgb, 0, 122, 204), 0.2);
    }
    to {
      box-shadow: 0 0 20px rgba(var(--primary-color-rgb, 0, 122, 204), 0.6);
    }
  }
  
  /* Add 3D depth effect */
  .profile-front::before,
  .profile-back::before {
    content: '';
    position: absolute;
    width: calc(100% - 10px);
    height: calc(100% - 10px);
    border-radius: 50%;
    top: 5px;
    left: 5px;
    background: linear-gradient(135deg, 
      rgba(255, 255, 255, 0.3) 0%, 
      rgba(255, 255, 255, 0) 50%, 
      rgba(0, 0, 0, 0.2) 100%);
    z-index: 3;
    pointer-events: none;
  }
  
  /* Darker overlay for the back image */
  .profile-back::before {
    background: linear-gradient(135deg, 
      rgba(0, 0, 0, 0.1) 0%, 
      rgba(0, 0, 0, 0) 50%, 
      rgba(0, 0, 0, 0.3) 100%);
  }
  
  /* Position the front and back sides */
  .profile-front, .profile-back {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    border-radius: 50%;
    overflow: hidden;
  }
  
  /* Style the front side (default) */
  .profile-front {
    z-index: 2;
  }
  
  /* Style the back side */
  .profile-back {
    transform: rotateY(180deg);
  }
    /* Style images in the flip container */
  .profile-front img, .profile-back img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    border: 5px solid var(--border-color);
    transition: all 0.5s ease;
  }
  
  /* Add a subtle pulse effect when the flip is triggered */
  .profile-flipper.flipping .profile-front img,
  .profile-flipper.flipping .profile-back img {
    animation: pulse 0.5s ease-in-out;
  }
  
  @keyframes pulse {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
    100% {
      transform: scale(1);
    }
  }
  
  @media (max-width: 992px) {
    .intro-text h1 {
      font-size: 3rem;
    }
    
    .intro-text h2 {
      font-size: 1.8rem;
    }
  }
  
  @media (max-width: 768px) {
    .intro-card {
      padding: 3rem 0;
    }
    
    .intro-content {
      flex-direction: column-reverse;
      text-align: center;
    }
    
    .intro-text p {
      margin-left: auto;
      margin-right: auto;
    }
    
    .cta-buttons {
      justify-content: center;
    }
      .profile-flip-container {
      width: 300px;
      height: 300px;
      margin-bottom: 2rem;
    }
  }
</style>

<script>
  // Add touch support for mobile devices and enhanced animations
  document.addEventListener('DOMContentLoaded', () => {
    const flipContainer = document.querySelector('.profile-flip-container') as HTMLElement | null;
    
    if (flipContainer) {
      const flipper = flipContainer.querySelector('.profile-flipper') as HTMLElement | null;
      
      if (!flipper) return;
      
      // Add touch event for mobile
      flipContainer.addEventListener('touchstart', function() {
        triggerFlip();
      });
      
      // Mouse hover events
      flipContainer.addEventListener('mouseenter', function() {
        flipper.classList.add('flipping');
      });
      
      flipContainer.addEventListener('mouseleave', function() {
        setTimeout(() => {
          flipper.classList.remove('flipping');
        }, 800);
      });
      
      // Function to trigger flip with animation
      const triggerFlip = () => {
        flipper.classList.add('flipping');
        const currentTransform = flipper.style.transform || '';
        const isFlipped = currentTransform.includes('rotateY(180deg)');
        flipper.style.transform = isFlipped ? 'rotateY(0deg)' : 'rotateY(180deg)';
        
        setTimeout(() => {
          flipper.classList.remove('flipping');
        }, 800);
      };
      
      // Add automatic flip every few seconds
      let autoFlipped = false;
      setInterval(() => {
        autoFlipped = !autoFlipped;
        flipper.classList.add('flipping');
        flipper.style.transform = autoFlipped ? 'rotateY(180deg)' : 'rotateY(0deg)';
        
        setTimeout(() => {
          flipper.classList.remove('flipping');
        }, 800);
      }, 6000); // Flip every 6 seconds
    }
  });
</script>
