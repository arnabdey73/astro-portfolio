---
// BaseLayout.astro - The main layout component for the portfolio
interface Props {
    title: string;
    description: string;
    type?: string;
    layout?: string;
    classes?: string[];
}

const { 
    title, 
    description, 
    type = "website", 
    layout = "default",
    classes = [] 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content={type} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title}</title>
        
        <!-- Preload theme initialization script to avoid flash -->
        <script is:inline src="/theme-init.js"></script>
        
        <!-- Preconnect to external resources -->
        <link rel="preconnect" href="https://astro-paper-project.vercel.app" />
        <link rel="preconnect" href="https://arnabdey73.github.io" />
        
        <!-- FontAwesome for icons -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" integrity="sha512-1ycn6IcaQQ40/MKBW2W4Rhis/DbILU74C1vSrLJxCq57o941Ym01SwNsOMqvEBFlcgUa6xLiPY/NS5R+E6ztJQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    </head>
    <body class:list={[layout, ...classes]}>
        <slot name="header" />
        <slot />
        <slot name="footer" />
    </body>
</html>

<style is:global>    /* Global styles */    :root {
        /* Light theme */
        --primary-color: #007acc;
        --primary-color-rgb: 0, 122, 204;
        --primary-dark: #005a99;
        --primary-dark-rgb: 0, 90, 153;
        --background-color: #ffffff;
        --background-color-rgb: 255, 255, 255;
        --text-color: #333333;
        --text-color-rgb: 51, 51, 51;
        --heading-color: #2c3e50;
        --heading-color-rgb: 44, 62, 80;
        --muted-text-color: #6c757d;
        --border-color: #e9ecef;
        --link-color: #007acc;
        --link-hover-color: #005a99;
        --section-background: #f8f9fa;
        --card-background: #ffffff;
        --footer-background: #f8f9fa;
        --hover-background: #f8f9fa;
        
        /* CSS Transition for theme change */
        color-scheme: light;
    }
    
    /* Dark theme */
    [data-theme="dark"] {
        --primary-color: #4da6ff;
        --primary-color-rgb: 77, 166, 255;
        --primary-dark: #0066cc;
        --primary-dark-rgb: 0, 102, 204;
        --background-color: #1a1a1a;
        --background-color-rgb: 26, 26, 26;
        --text-color: #e0e0e0;
        --text-color-rgb: 224, 224, 224;
        --heading-color: #ffffff;
        --heading-color-rgb: 255, 255, 255;
        --muted-text-color: #999999;
        --border-color: #333333;
        --link-color: #66b3ff;
        --link-hover-color: #4da6ff;
        --section-background: #1a1a1a;
        --card-background: #2d2d2d;
        --footer-background: #1a1a1a;
        --hover-background: #2d2d2d;
        
        color-scheme: dark;
    }
    
    /* Theme transition */
    .theme-transition {
        transition: background-color 0.3s ease, color 0.3s ease;
    }
    
    html, body {
        transition: background-color 0.3s ease;
    }
    
    img {
        max-width: 100%;
        height: auto;
    }
    
    a {
        color: var(--link-color);
        text-decoration: none;
        transition: color 0.2s ease;
    }
    
    a:hover {
        color: var(--link-hover-color);
    }
    
    h1, h2, h3, h4, h5, h6 {
        color: var(--heading-color);
        line-height: 1.2;
        margin-top: 0;
    }
    
    .splash {
        max-width: 1400px;
        margin: 0 auto;
    }
    
    /* Scroll behavior */
    html {
        scroll-behavior: smooth;
    }
    
    /* Reset */
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }
    
    body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        background-color: var(--background-color);
        color: var(--text-color);
        line-height: 1.6;
    }
</style>
